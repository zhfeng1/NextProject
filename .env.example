# 数据库配置
DB_PASSWORD=nextproject2025
DATABASE_URL=postgresql+asyncpg://admin:nextproject2025@postgres:5432/nextproject
SYNC_DATABASE_URL=postgresql+psycopg://admin:nextproject2025@postgres:5432/nextproject

# Redis / Celery
REDIS_PASSWORD=redis2025
REDIS_URL=redis://:redis2025@redis:6379/0
CELERY_BROKER_URL=redis://:redis2025@redis:6379/0
CELERY_RESULT_BACKEND=redis://:redis2025@redis:6379/1

# MinIO / Metrics
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin2025
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin2025
MINIO_SECURE=false
# 生成安全密钥：python3 -c 'import secrets; print(secrets.token_urlsafe(32))'
SECRET_KEY=replace-with-a-secure-random-secret-at-least-32-chars
# 加密密钥（Fernet），用于 API Key 加密存储，丢失不可恢复！请务必备份
# 生成命令：python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=replace-with-fernet-key
FLOWER_USER=admin
FLOWER_PASSWORD=admin2025
GRAFANA_PASSWORD=admin2025
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:18080,http://127.0.0.1:18080
CORS_ALLOW_CREDENTIALS=true

# 是否打印与大模型的完整对话日志（请求/响应）
# 可选值: true/false, 1/0, yes/no
LLM_DIALOG_LOG_ENABLED=false

# 日志中单个文本字段的最大长度，超出会截断
LLM_DIALOG_LOG_MAX_CHARS=4000

# 子网站进程端口范围（由主服务内部动态分配，不对外暴露）
SUB_SITE_PORT_START=19100
SUB_SITE_PORT_END=19999

# 任务执行 worker 数量
AGENT_TASK_WORKERS=2

# Playwright 冒烟测试入口（容器内部访问地址）
PLAYWRIGHT_BASE_URL=http://127.0.0.1:8080

# 多 CLI 默认命令（可按环境覆盖）
CODEX_CMD=codex
CLAUDE_CMD=claude
GEMINI_CMD=gemini

# 多 CLI 认证命令（可按环境覆盖）
CODEX_AUTH_CMD=codex login --device-auth
CLAUDE_AUTH_CMD=claude login
GEMINI_AUTH_CMD=gemini auth login
